# Database (set one PostgreSQL/Neon connection string)
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Required for admin routes and the temporary dashboard protection.
ADMIN_ACCESS_CODE=replace-with-a-long-random-secret

# Public form abuse protection. Use a unique high-entropy secret in every environment.
PUBLIC_FORM_RATE_LIMIT_SECRET=replace-with-a-long-random-secret

# Email/SMS notifications through Brevo. Omit these only in local development when
# notifications are intentionally disabled.
BREVO_API_KEY=
LEAD_FROM_EMAIL=Proffera <no-reply@example.com>
BREVO_SMS_SENDER=

# Optional Service AI Chat webhook integration. Keep its tenant isolated to Proffera.
CHAT_LEAD_WEBHOOK_SECRET=

# Stripe subscription billing. Use test keys/prices in Preview and Sandbox.
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_STARTER=price_replace_me
STRIPE_PRICE_PROFESSIONAL=price_replace_me
